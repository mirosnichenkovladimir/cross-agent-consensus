#!/usr/bin/env bash

set -uo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
SOURCE_DIR="$REPO_ROOT/skills/cross-agent-consensus"
TARGET=""
UPDATE=0
ALLOW_MISSING_FIRST_CLASS=0

usage() {
  cat <<'EOF'
Usage: scripts/install-cac --target hermes|codex|claude|all [--update] [--allow-missing-first-class]

Installs the cross-agent-consensus skill package.

Options:
  --target TARGET                 hermes, codex, claude, or all
  --update                        Update managed files when target copies are unmodified
  --allow-missing-first-class     With --target all, skip missing Hermes/Codex instead of failing
  -h, --help                      Show this help
EOF
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

err() {
  printf 'error: %s\n' "$*" >&2
}

detect_home() {
  local target="$1"
  local home_dir="${HOME:-}"

  case "$target" in
    hermes)
      if [[ -n "${HERMES_HOME:-}" ]]; then
        printf '%s\n' "$HERMES_HOME"
        return 0
      fi
      if [[ -n "$home_dir" && -d "$home_dir/.hermes" ]]; then
        printf '%s\n' "$home_dir/.hermes"
        return 0
      fi
      if command -v hermes >/dev/null 2>&1 && [[ -n "$home_dir" ]]; then
        printf '%s\n' "$home_dir/.hermes"
        return 0
      fi
      ;;
    codex)
      if [[ -n "${CODEX_HOME:-}" ]]; then
        printf '%s\n' "$CODEX_HOME"
        return 0
      fi
      if [[ -n "$home_dir" && -d "$home_dir/.codex" ]]; then
        printf '%s\n' "$home_dir/.codex"
        return 0
      fi
      if command -v codex >/dev/null 2>&1 && [[ -n "$home_dir" ]]; then
        printf '%s\n' "$home_dir/.codex"
        return 0
      fi
      ;;
    claude)
      if [[ -n "${CLAUDE_HOME:-}" ]]; then
        printf '%s\n' "$CLAUDE_HOME"
        return 0
      fi
      if [[ -n "$home_dir" && -d "$home_dir/.claude" ]]; then
        printf '%s\n' "$home_dir/.claude"
        return 0
      fi
      if command -v claude >/dev/null 2>&1 && [[ -n "$home_dir" ]]; then
        printf '%s\n' "$home_dir/.claude"
        return 0
      fi
      ;;
  esac

  return 1
}

install_to_target() {
  local target="$1"
  local home="$2"
  local target_dir="${home%/}/skills/cross-agent-consensus"
  local output
  local rc
  local status

  if ! command -v python3 >/dev/null 2>&1; then
    err "python3 is required for managed manifest install"
    return 1
  fi

  output="$(python3 - "$SOURCE_DIR" "$target_dir" "$UPDATE" <<'PY'
from __future__ import annotations

import datetime as _dt
import hashlib
import json
import shutil
import sys
from pathlib import Path

source_dir = Path(sys.argv[1]).resolve()
target_dir = Path(sys.argv[2]).expanduser()
update = sys.argv[3] == "1"
manifest_path = source_dir / "managed-manifest.json"
state_path = target_dir / ".cross-agent-consensus-managed.json"


def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as fh:
        for chunk in iter(lambda: fh.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def load_json(path: Path) -> dict:
    with path.open("r", encoding="utf-8") as fh:
        return json.load(fh)


if not source_dir.is_dir():
    print(f"source package not found: {source_dir}", file=sys.stderr)
    sys.exit(1)

if not manifest_path.is_file():
    print(f"managed manifest not found: {manifest_path}", file=sys.stderr)
    sys.exit(1)

try:
    manifest = load_json(manifest_path)
except Exception as exc:
    print(f"failed to parse managed manifest: {exc}", file=sys.stderr)
    sys.exit(1)

if manifest.get("package") != "cross-agent-consensus":
    print("managed manifest package must be cross-agent-consensus", file=sys.stderr)
    sys.exit(1)

managed = manifest.get("managed_files")
if not isinstance(managed, list) or not managed:
    print("managed manifest must contain a non-empty managed_files list", file=sys.stderr)
    sys.exit(1)

state = {}
if state_path.exists():
    try:
        state = load_json(state_path)
    except Exception as exc:
        print(f"failed to parse target managed state: {exc}", file=sys.stderr)
        sys.exit(1)
    if state.get("package") != "cross-agent-consensus":
        print(f"target state package mismatch: {state_path}", file=sys.stderr)
        sys.exit(1)

state_files = {}
for item in state.get("managed_files", []):
    if isinstance(item, dict) and "path" in item and "installed_sha256" in item:
        state_files[item["path"]] = item["installed_sha256"]

source_errors = []
conflicts = []
actions = []
seen = set()

for entry in managed:
    if not isinstance(entry, dict):
        source_errors.append("managed file entry is not an object")
        continue
    rel = entry.get("path")
    declared_hash = entry.get("sha256")
    if not isinstance(rel, str) or not rel:
        source_errors.append("managed file entry missing path")
        continue
    if rel.startswith("/") or ".." in Path(rel).parts:
        source_errors.append(f"{rel}: managed path must be relative and stay inside package")
        continue
    if rel in seen:
        source_errors.append(f"{rel}: duplicate managed path")
        continue
    seen.add(rel)
    if not isinstance(declared_hash, str) or len(declared_hash) != 64:
        source_errors.append(f"{rel}: sha256 must be a 64-character hex string")
        continue

    src = source_dir / rel
    dst = target_dir / rel
    if not src.is_file():
        source_errors.append(f"{rel}: source file missing")
        continue
    actual_source_hash = sha256_file(src)
    if actual_source_hash != declared_hash:
        source_errors.append(
            f"{rel}: manifest hash {declared_hash} does not match source hash {actual_source_hash}"
        )
        continue

    if dst.exists() and not dst.is_file():
        conflicts.append(f"{rel}: target path exists and is not a regular file")
        continue

    if dst.exists():
        target_hash = sha256_file(dst)
        previous_hash = state_files.get(rel)
        if previous_hash is None:
            conflicts.append(f"{rel}: target file exists but is not recorded as managed")
        elif target_hash != previous_hash:
            conflicts.append(
                f"{rel}: local modification detected; target hash {target_hash} differs from installed hash {previous_hash}"
            )
        elif update:
            if target_hash == actual_source_hash:
                actions.append(("keep", rel, actual_source_hash, "unchanged"))
            else:
                actions.append(("copy", rel, actual_source_hash, "updated"))
        else:
            if target_hash == actual_source_hash:
                actions.append(("keep", rel, actual_source_hash, "unchanged"))
            else:
                actions.append(("keep", rel, target_hash, "update_available"))
    else:
        actions.append(("copy", rel, actual_source_hash, "installed"))

if source_errors:
    print("Source package failed managed-manifest validation:", file=sys.stderr)
    for message in source_errors:
        print(f"  - {message}", file=sys.stderr)
    sys.exit(1)

if conflicts:
    print("Managed install conflicts; no files were overwritten:", file=sys.stderr)
    for message in conflicts:
        print(f"  - {message}", file=sys.stderr)
    print(
        "Hint: restore the target .cross-agent-consensus-managed.json state file, "
        "or manually remove/relocate unmanaged target files before reinstalling.",
        file=sys.stderr,
    )
    sys.exit(2)

installed = []
updated = []
unchanged = []
update_available = []

for action, rel, file_hash, status in actions:
    src = source_dir / rel
    dst = target_dir / rel
    if action == "copy":
        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dst)
    if status == "installed":
        installed.append(rel)
    elif status == "updated":
        updated.append(rel)
    elif status == "update_available":
        update_available.append(rel)
    else:
        unchanged.append(rel)

target_dir.mkdir(parents=True, exist_ok=True)
state_entries = []
for entry in managed:
    rel = entry["path"]
    dst = target_dir / rel
    if not dst.is_file():
        print(f"managed target file missing after install: {rel}", file=sys.stderr)
        sys.exit(1)
    state_entries.append(
        {
            "path": rel,
            "installed_sha256": sha256_file(dst),
            "source_sha256": entry["sha256"],
        }
    )

state_payload = {
    "package": "cross-agent-consensus",
    "schema_version": "m2-target-managed-state-1",
    "installed_at": _dt.datetime.now(_dt.timezone.utc).isoformat().replace("+00:00", "Z"),
    "source_root": str(source_dir),
    "source_manifest_sha256": sha256_file(manifest_path),
    "managed_files": state_entries,
}

tmp_state = state_path.with_suffix(state_path.suffix + ".tmp")
with tmp_state.open("w", encoding="utf-8") as fh:
    json.dump(state_payload, fh, indent=2, sort_keys=True)
    fh.write("\n")
tmp_state.replace(state_path)

print(f"Installed path: {target_dir}")
if installed:
    print("Installed managed files:")
    for rel in installed:
        print(f"  - {rel}")
if updated:
    print("Updated managed files:")
    for rel in updated:
        print(f"  - {rel}")
if update_available:
    print("Managed updates available; re-run with --update to apply:")
    for rel in update_available:
        print(f"  - {rel}")
if unchanged and not installed and not updated and not update_available:
    print("Managed files already current.")

if updated:
    final_status = "updated"
elif installed:
    final_status = "installed"
elif update_available:
    final_status = "skipped"
else:
    final_status = "unchanged"

print(f"__CAC_STATUS={final_status}")
PY
)"
  rc=$?

  if [[ $rc -ne 0 ]]; then
    printf '%s\n' "$output" >&2
    return "$rc"
  fi

  status="$(printf '%s\n' "$output" | awk -F= '/^__CAC_STATUS=/{print $2}' | tail -n 1)"
  printf '%s\n' "$output" | sed '/^__CAC_STATUS=/d'
  if [[ "$target" == "claude" ]]; then
    printf 'Note: Claude local skill discovery is best-effort until confirmed.\n'
  fi
  printf 'Trigger examples: cac: do design for <feature> | cac: implement this feature and do review\n'
  printf '__TARGET_STATUS=%s\n' "${status:-installed}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      if [[ $# -lt 2 ]]; then
        err "--target requires a value"
        exit 1
      fi
      TARGET="$2"
      shift 2
      ;;
    --target=*)
      TARGET="${1#--target=}"
      shift
      ;;
    --update)
      UPDATE=1
      shift
      ;;
    --allow-missing-first-class)
      ALLOW_MISSING_FIRST_CLASS=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      err "unknown argument: $1"
      usage >&2
      exit 1
      ;;
  esac
done

if [[ -z "$TARGET" ]]; then
  err "--target is required"
  usage >&2
  exit 1
fi

case "$TARGET" in
  hermes|codex|claude|all) ;;
  *)
    err "--target must be hermes, codex, claude, or all"
    exit 1
    ;;
esac

if [[ ! -d "$SOURCE_DIR" ]]; then
  err "source skill package not found: $SOURCE_DIR"
  exit 1
fi

targets=()
if [[ "$TARGET" == "all" ]]; then
  targets=(hermes codex claude)
else
  targets=("$TARGET")
fi

overall=0
results=()

for target in "${targets[@]}"; do
  home=""
  if ! home="$(detect_home "$target")"; then
    if [[ "$TARGET" == "all" && "$target" == "claude" ]]; then
      warn "Claude not detected; skipping best-effort target for --target all"
      results+=("claude: skipped (not detected; best-effort)")
      continue
    fi
    if [[ "$TARGET" == "all" && "$ALLOW_MISSING_FIRST_CLASS" -eq 1 ]]; then
      warn "$target not detected; skipping because --allow-missing-first-class was provided"
      results+=("$target: skipped (not detected)")
      continue
    fi
    if [[ "$target" == "claude" ]]; then
      err "Claude not detected. Set CLAUDE_HOME or create \$HOME/.claude to install the best-effort target."
    else
      case "$target" in
        hermes) env_name="HERMES_HOME" ;;
        codex) env_name="CODEX_HOME" ;;
        *) env_name="<TARGET>_HOME" ;;
      esac
      err "$target not detected. Set $env_name or create \$HOME/.$target to install this first-class target."
    fi
    results+=("$target: failed (not detected)")
    overall=1
    continue
  fi

  printf '\n==> Installing cross-agent-consensus for %s\n' "$target"
  output="$(install_to_target "$target" "$home")"
  rc=$?
  if [[ $rc -ne 0 ]]; then
    printf '%s\n' "$output" >&2
    results+=("$target: failed")
    overall=1
    continue
  fi
  status="$(printf '%s\n' "$output" | awk -F= '/^__TARGET_STATUS=/{print $2}' | tail -n 1)"
  printf '%s\n' "$output" | sed '/^__TARGET_STATUS=/d'
  results+=("$target: ${status:-installed} (${home%/}/skills/cross-agent-consensus)")
done

printf '\nSummary:\n'
for result in "${results[@]}"; do
  printf '  %s\n' "$result"
done

exit "$overall"
